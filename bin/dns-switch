#!/bin/bash
DNSV4="$1"
DNSV6="$2"

ACTIVE_DEVICES=$(nmcli -t -f DEVICE,STATE device | grep ":connected" | cut -d: -f1)

for DEV in $ACTIVE_DEVICES; do
    CONN=$(nmcli -t -f GENERAL.CONNECTION device show "$DEV" | cut -d: -f2)
    if [ -n "$CONN" ]; then
        if [ -z "$DNSV4" ]; then
            nmcli connection modify "$CONN" ipv4.ignore-auto-dns no ipv4.dns ""
        else
            nmcli connection modify "$CONN" ipv4.ignore-auto-dns yes ipv4.dns "$DNSV4"
        fi
        if [ -z "$DNSV6" ]; then
            nmcli connection modify "$CONN" ipv6.ignore-auto-dns no ipv6.dns ""
        else
            nmcli connection modify "$CONN" ipv6.ignore-auto-dns yes ipv6.dns "$DNSV6"
        fi
        nmcli connection up "$CONN" &
    fi
done